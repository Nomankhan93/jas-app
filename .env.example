# JAS App environment variables
# Copy this file to .env.local and fill in your Supabase project values.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only. Never expose this in browser/client code and never share .env.local.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional site URL used for QR verification links / deployment docs.
VITE_SITE_URL=http://localhost:3000
